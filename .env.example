# ===== 数据库连接（libSQL 兼容，本地/生产通用） =====
# 本地开发: file:./prisma/dev.db
# 生产 (Turso): libsql://your-db-name.turso.io
DATABASE_URL="file:./prisma/dev.db"

# Turso 生产环境需要 auth token（本地开发留空）
# 在 Turso 控制台创建: https://turso.tech → 数据库 → 生成 Token
DATABASE_AUTH_TOKEN=""

# ===== GitHub 采集 Token（提高 API 限额，推荐） =====
# GitHub → Settings → Developer settings → PAT 创建
GITHUB_TOKEN=""

# ===== 翻译 API（OpenAI 兼容接口，可选） =====
# 不配置时降级为保留英文原文
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# ===== 审核页面密码 =====
ADMIN_PASSWORD="admin123"
