# 数据库连接
# 本地开发: file:./dev.db
# 生产(Vercel/Turso): libsql://your-db.turso.io
# 注意: 用 Turso 时需安装 @prisma/adapter-libsql 并改用 adapter 方式连接
DATABASE_URL="file:./prisma/dev.db"

# GitHub 采集 Token (提高 API 限额, 可选但推荐)
# 在 GitHub → Settings → Developer settings → Personal access tokens 创建
GITHUB_TOKEN=""

# 翻译 API (OpenAI 兼容接口, 可选)
# 不配置时会降级为保留英文原文
OPENAI_API_KEY=""
# 自定义 Base URL (兼容 DeepSeek / Moonshot / 通义千问 等)
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# 审核页面密码
ADMIN_PASSWORD="admin123"
