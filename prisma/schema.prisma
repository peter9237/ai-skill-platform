generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Skill {
  id               String   @id @default(uuid())
  name             String
  nameLang         String   @default("en")
  summaryCn        String
  description      String?
  category         String
  tags             String   @default("[]")
  sourceUrl        String
  sourceType       String
  platform         String   @default("[\"通用\"]")
  installCmd       String?
  author           String?
  stars            Int      @default(0)
  viewCount        Int      @default(0)
  sourceUpdatedAt  String?
  status           String   @default("published")
  isNew            Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([stars])
  @@index([sourceUrl])
}

model CollectLog {
  id          String   @id @default(uuid())
  sourceName  String
  status      String
  newCount    Int      @default(0)
  updateCount Int      @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
}

model TranslationCache {
  id             String   @id @default(uuid())
  sourceHash     String   @unique
  originalText   String
  translatedText String
  createdAt      DateTime @default(now())
}
